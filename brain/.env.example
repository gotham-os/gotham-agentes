# MANIFEST_BASE_URL=http://gotham-roteador:2099/v1
# MANIFEST_API_KEY=

# === DATABASE ===
GOTHAM_DB_PATH=./gotham_memory.db

# === GOTHAM BROWSER MCP ===
# URL do servidor gotham-browser para os agentes usarem browser
GOTHAM_BROWSER_URL=http://gotham-browser:3100

# === SERVER ===
HOST=0.0.0.0
PORT=8000
