# === MANIFEST ROUTER (gotham-roteador) — PREFERIDO ===
# Quando ativo, cada Diretor usa sua chave Manifest → roteamento de LLM no dashboard
# Criar os agentes em: roteador.bmilimitada.com → Agents → New Agent
# Configurar routing por agente: primary model + fallback chain
MANIFEST_BASE_URL=https://roteador.bmilimitada.com/v1
MANIFEST_KEY_ALFRED=mnfst_xxx
MANIFEST_KEY_RAS=mnfst_xxx
MANIFEST_KEY_SELINA=mnfst_xxx
MANIFEST_KEY_BRUCE=mnfst_xxx

# === LLM DIRETO (fallback quando Manifest não configurado) ===
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === SEARCH TOOLS ===
TAVILY_API_KEY=

# === DATABASE ===
GOTHAM_DB_PATH=./gotham_memory.db

# === KNOWLEDGE / OUTPUTS ===
GOTHAM_KNOWLEDGE_PATH=./knowledge
GOTHAM_OUTPUTS_PATH=./outputs

# === SERVER ===
HOST=0.0.0.0
PORT=8000
