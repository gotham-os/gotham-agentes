# === LLM KEYS ===
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === SEARCH TOOLS ===
TAVILY_API_KEY=

# === MANIFEST ROUTER (gotham-roteador) ===
